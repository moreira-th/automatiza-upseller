{
  "manifest_version": 3,
  "name": "Tab Tiler",
  "version": "1.0",
  "description": "Organiza todas as abas lado a lado em grade",
  "permissions": ["tabs", "system.display", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tile Tabs"
  }
}
