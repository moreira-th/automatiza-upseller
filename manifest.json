{
  "manifest_version": 3,
  "name": "UpSeller Moreira",
  "version": "1.4.0",
  "description": "Automações para UpSeller: Remapeamento de Variantes + Tabela de Medidas + Descrições + Recorte de Imagem + Multi-Aba. Feito por Thales Moreira.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "contextMenus"
  ],
  "host_permissions": [
    "https://app.upseller.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.upseller.com/pt/products/shein/edit/*"
      ],
      "js": ["remap-content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "executar-macro": {
      "suggested_key": {
        "default": "Alt+Z"
      },
      "description": "Executa o preenchimento da tabela ativa (medidas)"
    },
    "aplicar-precos": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Aplica os últimos preços especiais salvos"
    }
  }
}
